{
  "name": "mybilibili-live-desktop",
  "productName": "mybilibili Live Desktop",
  "description": "mybilibili live streaming desktop based on OBS",
  "author": "mybilibili",
  "license": "GPL-3.0",
  "version": "1.21.3",
  "main": "main.js",
  "macVirtualCamUrl": "https://obs-studio-deployment.s3.us-west-2.amazonaws.com/slobs-vcam-installer-1.0.16-release-osx-[ARCH].tar.gz",
  "scripts": {
    "compile": "yarn clear && yarn webpack-cli --progress --config ./webpack.dev.config.js",
    "compile:production": "yarn clear && yarn webpack-cli --progress --config ./webpack.prod.config.js",
    "webpack-cli": "node --max-old-space-size=6144 node_modules/webpack-cli/bin/cli.js",
    "watch": "yarn clear && yarn webpack-cli --watch --progress --config ./webpack.dev.config.js",
    "watch:app": "yarn clear && yarn webpack-cli --watch --progress --config ./webpack.dev-app.config.js",
    "start": "electron .",
    "clear-plugins": "rimraf plugins",
    "package": "rimraf dist && electron-builder build -w --x64 --config electron-builder/base.config.js",
    "package:nosign": "yarn compile && cross-env MYBILIBILI_NO_SIGN=true yarn package",
    "eslint": "eslint \"app/**/*.ts\" \"app/**/*.tsx\" main.js",
    "clear": "rimraf bundles/media",
    "postinstall": "node ./scripts/postinstall.js",
    "tail-obs-logs": "node bin/tail-obs-logs.js",
    "beta": "MYBILIBILI_USE_BETA=true electron ."
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 100,
    "endOfLine": "lf",
    "trailingComma": "all",
    "arrowParens": "avoid"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "git add"
    ],
    "*.tsx": [
      "eslint --fix",
      "git add"
    ]
  },
  "ava": {
    "serial": true
  },
