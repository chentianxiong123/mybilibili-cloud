<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mybilibili.message.mapper.MessageSettingMapper">

    <resultMap id="MessageSettingMap" type="com.mybilibili.common.entity.MessageSetting">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="private_message_notification" property="privateMessageNotify"/>
        <result column="reply_notification" property="replyNotify"/>
        <result column="at_notification" property="atNotify"/>
        <result column="like_notification" property="likeNotify"/>
        <result column="system_notification" property="systemNotify"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <resultMap id="MessageSettingVOMap" type="com.mybilibili.common.vo.MessageSettingVO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="private_message_notification" property="privateMessageNotify"/>
        <result column="reply_notification" property="replyNotify"/>
        <result column="at_notification" property="atNotify"/>
        <result column="like_notification" property="likeNotify"/>
        <result column="system_notification" property="systemNotify"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.mybilibili.common.entity.MessageSetting" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO message_settings (user_id, private_message_notification, reply_notification, at_notification, like_notification, system_notification, created_at, updated_at)
        VALUES (#{userId}, #{privateMessageNotify}, #{replyNotify}, #{atNotify}, #{likeNotify}, #{systemNotify}, NOW(), NOW())
    </insert>

    <select id="selectById" parameterType="java.lang.Long" resultMap="MessageSettingMap">
        SELECT * FROM message_settings WHERE id = #{id}
    </select>

    <select id="selectByUserId" parameterType="java.lang.Integer" resultMap="MessageSettingMap">
        SELECT * FROM message_settings WHERE user_id = #{userId}
    </select>

    <select id="selectVOByUserId" parameterType="java.lang.Integer" resultMap="MessageSettingVOMap">
        SELECT * FROM message_settings WHERE user_id = #{userId}
    </select>

    <update id="update" parameterType="com.mybilibili.common.entity.MessageSetting">
        UPDATE message_settings
        SET private_message_notification = #{privateMessageNotify},
            reply_notification = #{replyNotify},
            at_notification = #{atNotify},
            like_notification = #{likeNotify},
            system_notification = #{systemNotify},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>