# PostHog Analytics (optional)
# Get your keys at https://posthog.com
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

# mybilibili 主系统接入
# 浏览器默认请求 /api，开发服务器会代理到 VITE_MYBILIBILI_API_PROXY_TARGET。
VITE_MYBILIBILI_API_BASE_URL=/api
VITE_MYBILIBILI_API_PROXY_TARGET=http://127.0.0.1:8080
VITE_MYBILIBILI_WEB_URL=http://127.0.0.1:5173
