{
  "name": "mybilibili-studio",
  "version": "0.1.0",
  "private": true,
  "description": "mybilibili Creator Studio - Professional video editing",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @mybilibili-studio/web dev",
    "build:wasm": "pnpm --filter @mybilibili-studio/core build:wasm",
    "build": "pnpm --filter @mybilibili-studio/web build",
    "preview": "pnpm --filter @mybilibili-studio/web preview",
    "deploy": "pnpm build && pnpm --filter @mybilibili-studio/web deploy",
    "deploy:preview": "pnpm build && pnpm --filter @mybilibili-studio/web deploy:preview",
    "test": "pnpm -r test:run",
    "test:watch": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "claude:help": "cat scripts/claude-review.md",
    "issues": "gh issue list --label needs-claude-review",
    "prs": "gh pr list --label needs-claude-review"
  },
  "keywords": [
    "video-editor",
    "audio-editor",
    "browser-based",
    "webcodecs",
    "webgpu",
    "react",
    "typescript",
    "open-source",
    "video-editing",
    "timeline",
    "color-grading",
    "export"
  ],
  "author": "Augustus Otu and Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@11.5.1",
  "dependencies": {
    "@ffmpeg/core": "0.12.6",
    "@ffmpeg/core-mt": "0.12.6",
    "mediabunny": "^1.25.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}